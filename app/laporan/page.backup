/* eslint-disable @typescript-eslint/no-explicit-any */
"use client";

import { useCallback, useEffect, useRef, useState } from "react";
import { useSession } from "next-auth/react";
import { usePathname, useRouter, useSearchParams } from "next/navigation";
import { addDays, format, subDays } from "date-fns";
import * as XLSX from "xlsx";

type ReportProductFilter = "all" | "phone" | "accessory" | "voucher" | "pulsa";
type ReportCategory = "HANDPHONE" | "PRODUK_LAIN" | "PULSA";

type ReportTransaction = {
  id: string;
  createdAt: string;
  category?: ReportCategory;
  status: "PAID" | "REFUND";
  totalAmount: number;
  totalCost: number;
  profit: number;
  note?: string | null;
  debt_note: string;
  invoiceNumber?: string | null;
  items: Array<{
    id?: string;
    quantity: number;
    sellPrice: number;
    costPrice: number;
    pulsaDestinationNumber?: string | null;
    pulsaDescription?: string | null;
    pulsaBalance?: number | null;
    phone?: {
      brand: string;
      type: string;
      imei: string;
      color?: string | null;
      purchaseDate?: string | Date | null;
      purchasePrice: number;
      metadata?: Array<{ key: string; value: string }>;
    } | null;
    accessory?: { name: string; code: string } | null;
    voucher?: { name: string; code: string } | null;
    pulsa?: {
      denomination: number;
      note?: string | null;
      destinationNumber?: string | null;
      description?: string | null;
    } | null;
  }>;
};

type ReportRow = {
  key: string;
  transactionId: string;
  debt_note: string;
  dateKey: string;
  category: string;
  product: string;
  quantity: number;
  cost: number;
  revenue: number;
  profit: number;
  detail: string;
};

type PulsaRow = {
  key: string;
  transactionId: string;
  dateKey: string;
  destinationNumber: string;
  debt_note: string;
  description: string;
  modal: number;
  price: number;
  total: number;
  profit: number;
  balance: number | null;
};

const categoryEndpointMap: Record<ReportCategory, string> = {
  HANDPHONE: "/api/laporan/hp",
  PRODUK_LAIN: "/api/laporan/produk-lain",
  PULSA: "/api/laporan/pulsa",
};

const filterToCategory: Record<Exclude<ReportProductFilter, "all">, ReportCategory> = {
  phone: "HANDPHONE",
  accessory: "PRODUK_LAIN",
  voucher: "PRODUK_LAIN",
  pulsa: "PULSA",
};

const rupiah = (value: number) => `Rp ${Math.round(value || 0).toLocaleString("id-ID")}`;

const toDateKey = (value: string | Date | null | undefined) => {
  if (!value) return "";
  const date = value instanceof Date ? value : new Date(value);
  return Number.isNaN(date.getTime()) ? "" : format(date, "yyyy-MM-dd");
};

const toDateDisplay = (dateKey: string) => {
  if (!dateKey) return "";
  const [y, m, d] = dateKey.split("-");
  return `${d}/${m}/${y}`;
};

const getItemType = (item: ReportTransaction["items"][number]) => {
  if (item.phone) return "phone";
  if (item.accessory) return "accessory";
  if (item.voucher) return "voucher";
  if (item.pulsa || item.pulsaDestinationNumber) return "pulsa";
  return "unknown";
};

const getItemProduct = (item: ReportTransaction["items"][number]) => {
  if (item.phone) return `${item.phone.brand} ${item.phone.type}`;
  if (item.accessory) return item.accessory.name;
  if (item.voucher) return item.voucher.name;
  if (item.pulsa) return `${item.pulsa.denomination.toLocaleString("id-ID")} Pulsa`;
  return "-";
};

const getItemCategory = (item: ReportTransaction["items"][number]) => {
  if (item.phone) return "HP";
  if (item.accessory) return "Aksesoris";
  if (item.voucher) return "Voucher";
  if (item.pulsa) return "Pulsa";
  return "-";
};

const getItemDetail = (item: ReportTransaction["items"][number]) => {
  if (item.phone) return `IMEI: ${item.phone.imei}`;
  if (item.accessory) return `Kode: ${item.accessory.code}`;
  if (item.voucher) return `Kode: ${item.voucher.code}`;
  if (item.pulsa) return item.pulsaDestinationNumber || item.pulsa.description || item.pulsa.note || "-";
  return "-";
};

const buildRows = (transactions: ReportTransaction[], filter: ReportProductFilter) => {
  const rows: ReportRow[] = [];

  [...transactions]
    .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
    .forEach((trx) => {
      const dateKey = toDateKey(trx.createdAt);
      if (!dateKey) return;

      trx.items.forEach((item, idx) => {
        const itemType = getItemType(item);
        if (filter === "accessory" && itemType !== "accessory" && itemType !== "voucher") return;
        if (filter !== "all" && filter !== "accessory" && itemType !== filter) return;

        const qty = Number(item.quantity || 1);
        const multiplier = trx.status === "REFUND" ? 0 : 1;

        rows.push({
          key: `${trx.id}-${idx}`,
          transactionId: trx.id,
          debt_note: trx.debt_note,
          dateKey,
          category: getItemCategory(item),
          product: getItemProduct(item),
          quantity: qty,
          cost: Number(item.costPrice || 0) * qty * multiplier,
          revenue: Number(item.sellPrice || 0) * qty * multiplier,
          profit: (Number(item.sellPrice || 0) - Number(item.costPrice || 0)) * qty * multiplier,
          detail: getItemDetail(item),
        });
      });
    });

  return rows;
};

const buildPulsaRows = (transactions: ReportTransaction[]) => {
  const rows: PulsaRow[] = [];

  [...transactions]
    .sort((a, b) => new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime())
    .forEach((trx) => {
      const dateKey = toDateKey(trx.createdAt);
      if (!dateKey) return;

      trx.items.forEach((item, idx) => {
        if (!item.pulsa && !item.pulsaDestinationNumber && trx.category !== "PULSA") return;

        const multiplier = trx.status === "REFUND" ? 0 : 1;
        const qty = Number(item.quantity || 1);

        rows.push({
          key: `${trx.id}-${idx}`,
          transactionId: trx.id,
          dateKey,
          destinationNumber: item.pulsaDestinationNumber || item.pulsa?.destinationNumber || "-",
          debt_note: trx.debt_note,
          description: item.pulsaDescription || item.pulsa?.description || item.pulsa?.note || "-",
          modal: Number(trx.totalCost ?? item.costPrice ?? 0) * multiplier,
          price: Number(item.sellPrice ?? trx.totalAmount ?? 0) * multiplier,
          total: Number(trx.totalAmount ?? item.sellPrice ?? 0) * multiplier,
          profit: Number(trx.profit ?? 0) * multiplier,
          balance: item.pulsaBalance ?? null,
        });
      });
    });

  return rows;
};

const groupRowsByDate = (rows: ReportRow[]) => {
  const map = new Map<string, ReportRow[]>();
  rows.forEach((row) => {
    if (!map.has(row.dateKey)) map.set(row.dateKey, []);
    map.get(row.dateKey)!.push(row);
  });
  return Array.from(map.entries())
    .sort(([a], [b]) => b.localeCompare(a))
    .map(([dateKey, items]) => ({ dateKey, rows: items }));
};

const groupPulsaByDate = (rows: PulsaRow[]) => {
  const map = new Map<string, PulsaRow[]>();
  rows.forEach((row) => {
    if (!map.has(row.dateKey)) map.set(row.dateKey, []);
    map.get(row.dateKey)!.push(row);
  });
  return Array.from(map.entries())
    .sort(([a], [b]) => b.localeCompare(a))
    .map(([dateKey, items]) => ({ dateKey, rows: items }));
};

async function fetchCategoryReport(
  startDate: string,
  endDate: string,
  categories: ReportCategory[],
  search: string,
  page: number
) {
  const responses = await Promise.all(
    categories.map(async (category) => {
      const url = new URL(categoryEndpointMap[category], window.location.origin);
      url.searchParams.set("startDate", startDate);
      url.searchParams.set("endDate", endDate);
      url.searchParams.set("search", search);
      url.searchParams.set("page", page.toString());
      url.searchParams.set("pageSize", "3");

      const res = await fetch(url.toString());
      if (!res.ok) throw new Error(`Gagal mengambil laporan ${category}`);
      return res.json();
    })
  );

  const summary = responses.reduce(
    (acc, r) => {
      const s = r.summary || {};
      return {
        totalRevenue: acc.totalRevenue + (s.totalRevenue || 0),
        totalCost: acc.totalCost + (s.totalCost || 0),
        totalProfit: acc.totalProfit + (s.totalProfit || 0),
        todayProfit: acc.todayProfit + (s.todayProfit || 0),
        transactionCount: acc.transactionCount + (s.transactionCount || 0),
      };
    },
    { totalRevenue: 0, totalCost: 0, totalProfit: 0, todayProfit: 0, transactionCount: 0 }
  );

  return {
    transactions: responses.flatMap((r) => r.transactions || []),
    summary,
    pagination: responses[0]?.pagination || { page: 1, pageSize: 6, totalCount: 0, totalPages: 0, hasNextPage: false, hasPreviousPage: false },
  };
}

export default function LaporanKeuanganPage() {
  const { status } = useSession();
  const router = useRouter();
  const pathname = usePathname();
  const searchParams = useSearchParams();

  const [summary, setSummary] = useState({ totalRevenue: 0, totalCost: 0, totalProfit: 0, todayProfit: 0, transactionCount: 0 });
  const [transactions, setTransactions] = useState<ReportTransaction[]>([]);
  const [loading, setLoading] = useState(true);
  const [startDate, setStartDate] = useState(format(subDays(new Date(), 30), "yyyy-MM-dd"));
  const [endDate, setEndDate] = useState(format(addDays(new Date(), 1), "yyyy-MM-dd"));
  const [productFilter, setProductFilter] = useState<ReportProductFilter>("all");
  const [debtNotes, setDebtNotes] = useState<Record<string, string>>({});
  const [updatingStatusTxId, setUpdatingStatusTxId] = useState<string | null>(null);
  const [page, setPage] = useState(1);
  const [search, setSearch] = useState("");
  const [exporting, setExporting] = useState(false);
  const [pagination, setPagination] = useState({ page: 1, pageSize: 6, totalCount: 0, totalPages: 0, hasNextPage: false, hasPreviousPage: false });

  const inFlightRef = useRef<string | null>(null);

  const fixedFilter: ReportProductFilter | null =
    pathname === "/laporan/hp" ? "phone" :
    pathname === "/laporan/produk-lain" ? "accessory" :
    pathname === "/laporan/pulsa" ? "pulsa" : null;

  const effectiveFilter = fixedFilter ?? productFilter;

  useEffect(() => {
    if (fixedFilter) {
      setProductFilter(fixedFilter);
      return;
    }
    const cat = searchParams.get("category");
    if (cat === "HANDPHONE") setProductFilter("phone");
    else if (cat === "PRODUK_LAIN") setProductFilter("accessory");
    else if (cat === "PULSA") setProductFilter("pulsa");
  }, [fixedFilter, searchParams]);

  useEffect(() => { setPage(1); }, [effectiveFilter, startDate, endDate, search]);

  const fetchLaporan = useCallback(async () => {
    const key = `${effectiveFilter}|${startDate}|${endDate}|${page}|${search}`;
    if (inFlightRef.current === key) return;
    inFlightRef.current = key;

    setLoading(true);
    try {
      const cats: ReportCategory[] = effectiveFilter === "all"
        ? ["HANDPHONE", "PRODUK_LAIN", "PULSA"]
        : [filterToCategory[effectiveFilter]];

      const report = await fetchCategoryReport(startDate, endDate, cats, search, page);
      setTransactions(report.transactions);
      setPagination(report.pagination);
      setSummary(report.summary);
    } catch (error) {
      console.error(error);
    } finally {
      if (inFlightRef.current === key) inFlightRef.current = null;
      setLoading(false);
    }
  }, [effectiveFilter, endDate, startDate, search, page]);

  useEffect(() => {
    if (status === "unauthenticated") { router.push("/login"); return; }
    if (status === "authenticated") fetchLaporan();
  }, [fetchLaporan, router, status]);

  const handleDebtNoteSave = async (txId: string, value: string) => {
    try {
      await fetch(`/api/transactions/${txId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ debt_note: value }),
      });
      await fetchLaporan();
    } catch (error) {
      console.error(error);
    }
  };

  const updateStatus = async (txId: string, status: "PAID" | "REFUND") => {
    try {
      setUpdatingStatusTxId(txId);
      await fetch(`/api/transactions/${txId}`, {
        method: "PATCH",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ status }),
      });
      await fetchLaporan();
      setPage(1);
    } catch (error) {
      console.error(error);
    } finally {
      setUpdatingStatusTxId(null);
    }
  };

  const exportToExcel = async () => {
    setExporting(true);
    try {
      const cat = effectiveFilter === "phone" ? "HANDPHONE" : effectiveFilter === "pulsa" ? "PULSA" : "PRODUK_LAIN";
      const url = new URL("/api/laporan/exports", window.location.origin);
      url.searchParams.set("category", cat);
      url.searchParams.set("startDate", startDate);
      url.searchParams.set("endDate", endDate);

      const res = await fetch(url.toString());
      if (!res.ok) throw new Error("Gagal mengambil data export");
      const data = await res.json();
      const reports = data.reports || [];

      if (effectiveFilter === "phone") {
        const aoa: any[][] = [["MERK", "TYPE", "IMEI", "WARNA", "TGL_BELI", "BELI_DARI", "HARGA_BELI", "Ket_Serv", "BIAYA_SERVICE", "TGL_JUAL", "HARGA_JUAL", "RL"]];
        reports.forEach((g: any) => {
          aoa.push([`TGL JUAL: ${toDateDisplay(g.date)}`, "", "", "", "", "", "", "", "", "", "", ""]);
          g.items.forEach((item: any) => {
            aoa.push([item.brand, item.type, item.imei, item.color, toDateDisplay(item.purchaseDate), item.beliDari, item.purchasePrice, item.ketServ, item.serviceCost, toDateDisplay(g.date), item.sellPrice, item.profit]);
          });
          aoa.push([`Subtotal ${toDateDisplay(g.date)}`, "", "", "", "", "", g.subtotalHPP, "", "", "", g.subtotalHPJ, g.subtotalRL]);
        });
        aoa.push(["", "", "", "", "", "", "", "", "", "", "", ""]);
        aoa.push(["", "", "", "", "", "HPP", data.summary.totalHPP, "", "", "", "HPJ", data.summary.totalHPJ, "RL", data.summary.totalRL]);
        const ws = XLSX.utils.aoa_to_sheet(aoa);
        ws["!cols"] = Array(12).fill({ wch: 14 });
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Laporan HP");
        XLSX.writeFile(wb, `Laporan_HP_${startDate}_sd_${endDate}.xlsx`);
      }
    } catch (error) {
      console.error(error);
    } finally {
      setExporting(false);
    }
  };

  const allRows = buildRows(transactions, effectiveFilter);
  const groupedRows = groupRowsByDate(allRows);
  const statusMap = new Map(transactions.map((t) => [t.id, t.status]));

  return (
    <div className="relative mx-auto max-w-7xl space-y-8 px-4 py-6 sm:px-6 lg:px-8">
      <div className="pointer-events-none absolute inset-x-0 top-0 -z-10 h-64 bg-[radial-gradient(circle_at_top_right,_rgba(139,92,246,0.18),_transparent_45%),radial-gradient(circle_at_top_left,_rgba(16,185,129,0.12),_transparent_35%)]" />

      {/* Header + Cards */}
      <div className="overflow-hidden rounded-[2rem] border border-white/60 bg-white/75 shadow-[0_20px_60px_rgba(15,23,42,0.08)] backdrop-blur-xl">
        <div className="flex flex-col gap-6 border-b border-slate-200/70 bg-gradient-to-br from-slate-950 via-slate-900 to-slate-800 px-6 py-8 text-white sm:px-8">
          <div>
            <div className="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.28em] text-white/80">Taurus Cellular</div>
            <h1 className="mt-3 text-3xl font-semibold sm:text-4xl">Laporan Keuangan</h1>
          </div>
        </div>

        <div className="grid gap-4 border-b border-slate-200/70 bg-slate-50/80 px-6 py-6 sm:grid-cols-4 sm:px-8">
          {[
            { label: "Pendapatan", value: summary.totalRevenue, color: "violet" },
            { label: "Modal", value: summary.totalCost, color: "amber" },
            { label: "Laba", value: summary.totalProfit, color: "emerald" },
            { label: "Hari Ini", value: summary.todayProfit, color: "sky" },
          ].map((card) => (
            <div key={card.label} className={`rounded-3xl border border-${card.color}-100 bg-gradient-to-br from-${card.color}-50 to-white p-5 shadow-sm`}>
              <p className={`text-xs font-semibold uppercase tracking-[0.2em] text-${card.color}-500`}>{card.label}</p>
              <p className={`mt-4 text-3xl font-semibold text-${card.color}-600`}>{rupiah(card.value)}</p>
            </div>
          ))}
        </div>
      </div>

      {/* Filters */}
      <div className="rounded-[2rem] border border-white/70 bg-white/80 p-6 shadow-[0_20px_60px_rgba(15,23,42,0.08)] backdrop-blur-xl">
        <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
          <div>
            <label className="mb-2 block text-sm font-semibold text-slate-600">Tanggal Mulai</label>
            <input type="date" value={startDate} onChange={(e) => setStartDate(e.target.value)} className="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 focus:border-transparent focus:ring-2 focus:ring-violet-500" />
          </div>
          <div>
            <label className="mb-2 block text-sm font-semibold text-slate-600">Tanggal Akhir</label>
            <input type="date" value={endDate} onChange={(e) => setEndDate(e.target.value)} className="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 focus:border-transparent focus:ring-2 focus:ring-violet-500" />
          </div>
          <div>
            <label className="mb-2 block text-sm font-semibold text-slate-600">Pencarian</label>
            <input type="text" placeholder="Cari invoice atau imei..." value={search} onChange={(e) => setSearch(e.target.value)} className="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 focus:border-transparent focus:ring-2 focus:ring-violet-500" />
          </div>
          <div className="flex items-end">
            <button onClick={exportToExcel} disabled={exporting} className={`w-full rounded-2xl px-4 py-3 text-sm font-semibold transition ${exporting ? "bg-gray-300 text-gray-500" : "bg-emerald-600 text-white hover:bg-emerald-700"}`}>
              {exporting ? "Mengexport..." : "Export ke Spreadsheet"}
            </button>
          </div>
        </div>
      </div>

      {/* Table */}
      <div className="overflow-hidden rounded-[2rem] border border-white/70 bg-white/80 shadow-[0_20px_60px_rgba(15,23,42,0.08)] backdrop-blur-xl">
        <div className="px-6 py-6 sm:px-8 border-b border-slate-200/70 bg-slate-50/80">
          <h2 className="text-xl font-semibold text-slate-900">Detail Transaksi</h2>
          <p className="text-sm text-slate-500 mt-1">{pagination.totalCount} total transaksi</p>
        </div>

        {loading ? (
          <div className="px-8 py-12 text-center text-slate-500">Memuat laporan...</div>
        ) : transactions.length === 0 ? (
          <div className="px-8 py-12 text-center text-slate-500">Belum ada data pada periode ini.</div>
        ) : (
          <div className="overflow-x-auto">
            <table className="w-full min-w-[1100px]">
              <thead className="sticky top-0 z-10">
                <tr className="bg-gray-50">
                  <th className="px-6 py-4 text-left text-sm font-semibold text-slate-600 uppercase">Item</th>
                  <th className="px-6 py-4 text-left text-sm font-semibold text-slate-600 uppercase">Catatan</th>
                  <th className="px-6 py-4 text-left text-sm font-semibold text-slate-600 uppercase">Kategori</th>
                  <th className="px-6 py-4 text-left text-sm font-semibold text-slate-600 uppercase">Detail</th>
                  <th className="px-6 py-4 text-right text-sm font-semibold text-slate-600 uppercase">Qty</th>
                  <th className="px-6 py-4 text-right text-sm font-semibold text-slate-600 uppercase">Modal</th>
                  <th className="px-6 py-4 text-right text-sm font-semibold text-slate-600 uppercase">Jual</th>
                  <th className="px-6 py-4 text-right text-sm font-semibold text-slate-600 uppercase">Laba/Rugi</th>
                  <th className="px-6 py-4 text-left text-sm font-semibold text-slate-600 uppercase">Status</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-slate-100">
                {groupedRows.map((group) =>
                  group.rows.map((row) => (
                    <tr key={row.key} className="hover:bg-gray-50">
                      <td className="px-6 py-4">
                        <div className="font-medium text-slate-900">{row.product}</div>
                        <div className="text-xs text-slate-500">{toDateDisplay(row.dateKey)}</div>
                      </td>
                      <td className="px-6 py-4">
                        <input
                          value={debtNotes[row.transactionId] ?? ""}
                          onChange={(e) => setDebtNotes((p) => ({ ...p, [row.transactionId]: e.target.value }))}
                          onBlur={(e) => handleDebtNoteSave(row.transactionId, e.target.value)}
                          placeholder="Catatan"
                          className="bg-blue-50 rounded-md p-2 text-sm w-full"
                        />
                      </td>
                      <td className="px-6 py-4 text-sm text-slate-700">{row.category}</td>
                      <td className="px-6 py-4 text-sm text-slate-700">{row.detail}</td>
                      <td className="px-6 py-4 text-right text-sm text-slate-700">{row.quantity}</td>
                      <td className="px-6 py-4 text-right text-sm text-slate-700">{rupiah(row.cost)}</td>
                      <td className="px-6 py-4 text-right text-sm text-slate-700">{rupiah(row.revenue)}</td>
                      <td className={`px-6 py-4 text-right text-sm font-semibold ${row.profit >= 0 ? "text-emerald-600" : "text-red-600"}`}>{rupiah(row.profit)}</td>
                      <td className="px-6 py-4">
                        <select
                          className="rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm"
                          value={statusMap.get(row.transactionId) ?? "PAID"}
                          onChange={(e) => updateStatus(row.transactionId, e.target.value as "PAID" | "REFUND")}
                          disabled={updatingStatusTxId === row.transactionId}
                        >
                          <option value="PAID">PAID</option>
                          <option value="REFUND">REFUND</option>
                        </select>
                      </td>
                    </tr>
                  ))
                )}
              </tbody>
            </table>
          </div>
        )}
      </div>

      {/* Pagination */}
      {pagination.totalCount > 0 && (
        <div className="flex items-center justify-center gap-3">
          <button onClick={() => setPage((p) => Math.max(1, p - 1))} disabled={!pagination.hasPreviousPage} className="rounded-xl border bg-white px-4 py-2 text-sm disabled:opacity-50">Previous</button>
          <span className="text-sm text-slate-600">Halaman {pagination.page} dari {pagination.totalPages}</span>
          <button onClick={() => setPage((p) => p + 1)} disabled={!pagination.hasNextPage} className="rounded-xl border bg-white px-4 py-2 text-sm disabled:opacity-50">Next</button>
        </div>
      )}
    </div>
  );
}