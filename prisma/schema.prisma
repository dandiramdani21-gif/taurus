// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

// ================= ENUM =================
enum TransactionType {
  SALE
  PURCHASE
}

enum TransactionStatus {
  PAID
  REFUND
}

enum ProductCategory {
  HANDPHONE
  PRODUK_LAIN
  PULSA
}

enum RestockSource {
  MANUAL
  SCAN
  IMPORT
  ADJUSTMENT
}

// ================= USER =================
model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String

  createdAt DateTime @default(now())

  transactions Transaction[]
  restockNotes RestockNote[]
}

// ================= PHONE (HP) =================
model Phone {
  id        String  @id @default(cuid())
  brand     String
  type      String
  imei      String  @unique
  color     String?
  category  ProductCategory @default(HANDPHONE)

  purchasePrice Int
  purchaseDate  DateTime @default(now())
  entryDate     DateTime @default(now())

  stock Int @default(1)
  isHidden Boolean @default(false)
  deleted Boolean @default(false)
  
  image String?

  createdAt        DateTime          @default(now())
  transactionItems TransactionItem[]
  
  metadata PhoneMetadata[]
}

// ================= PHONE METADATA (Dynamic) =================
model PhoneMetadata {
  id        String @id @default(cuid())
  phoneId   String
  phone     Phone  @relation(fields: [phoneId], references: [id], onDelete: Cascade)
  key       String
  value     String
  
  createdAt DateTime @default(now())
  
  @@unique([phoneId, key])
}

// ================= ACCESSORY =================
model Accessory {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  costPrice Int
  sellPrice Int
  stock     Int      @default(0)
  image     String?
  entryDate DateTime @default(now())
  category  ProductCategory @default(PRODUK_LAIN)
  deleted   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  transactionItems TransactionItem[]
}

// ================= VOUCHER =================
model Voucher {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  costPrice Int      // harga modal
  sellPrice Int      // harga jual
  stock     Int      @default(0)
  image     String?
  entryDate DateTime @default(now())
  expiredAt DateTime? // tanggal expired (opsional)
  category  ProductCategory @default(PRODUK_LAIN)
  deleted   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  transactionItems TransactionItem[]
}

// ================= PULSA =================
model Pulsa {
  id          String   @id @default(cuid())
  code        String   @unique
  denomination Int      // nominal pulsa: 5,10,15,20,25,30,40,50,70,100
  costPrice   Int      // harga modal
  sellPrice   Int      // harga jual
  balance     Int?     // saldo transaksi / sisa saldo operator
  destinationNumber String? // no tujuan
  description String?  // keterangan tambahan
  note        String?  // TAGOG, DIGIPOS, PROMO, REGULER
  image       String?
  category    ProductCategory @default(PULSA)
  deleted     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  transactionItems TransactionItem[]
}

// ================= TRANSACTION =================
model Transaction {
  id     String            @id @default(cuid())
  invoiceNumber String?    @unique
  type   TransactionType
  status TransactionStatus @default(PAID)
  category ProductCategory @default(HANDPHONE)
  deleted Boolean @default(false)

  totalAmount Int
  totalCost   Int
  profit      Int

  note String?
  servedByName String?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items TransactionItem[]

  @@index([createdAt])
}

// ================= TRANSACTION ITEM =================
model TransactionItem {
  id String @id @default(cuid())

  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id])

  // Support multiple product types
  accessoryId String?
  accessory   Accessory? @relation(fields: [accessoryId], references: [id])
  
  voucherId String?
  voucher   Voucher? @relation(fields: [voucherId], references: [id])
  
  pulsaId String?
  pulsa   Pulsa? @relation(fields: [pulsaId], references: [id])
  pulsaDestinationNumber String?
  pulsaDescription String?
  pulsaBalance Int?

  phoneId String?
  phone   Phone? @relation(fields: [phoneId], references: [id])

  quantity Int @default(1)
  sellPrice Int
  costPrice Int
}

// ================= RESTOCK NOTE =================
model RestockNote {
  id String @id @default(cuid())

  category ProductCategory
  productType String
  productId String
  productName String

  source RestockSource @default(MANUAL)
  quantity Int
  previousStock Int
  newStock Int
  costPrice Int?
  note String?

  userId String?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([category, productType])
  @@index([productId])
  @@index([createdAt])
}
